NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=https://your-vercel-frontend.vercel.app
CLIENT_URLS=https://your-vercel-frontend.vercel.app
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# Optional local development fallback only
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/FundBridgeMONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/FundBridge?retryWrites=true&w=majority
PORT=5000
JWT_SECRET=change_this_to_a_secure_random_value
CLIENT_URLS=http://localhost:5173,http://localhost:3000
# Optional Firebase settings
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./serviceAccountKey.json
